  <%- include('partials/header') %>
  <main class="mt-8 flex flex-col justify-center items-center">
    <h1 class="text-amber-500 font-bold text-2xl font-['Outfit sans-serif']">Our Registered Homes</h1>
    <div class="mt-5 rounded flex flex-row justify-center">
      <ul class="text-[#FFFDEB] text-xl bg-[#ff385c] rounded">
      <% formDetails.forEach(home => { %>
        <li class="border-2 border-amber-100 p-3 m-4 rounded w-96 bg-white text-black">
          <% if (home.imageUrl) { %>
            <div class="flex justify-center mb-4">
              <img src="<%= home.imageUrl %>" alt="Registered house listing" class="w-full h-48 object-cover rounded" />
            </div>
          <% } %>
          <div class="text-center mb-2 font-semibold text-lg">
            <%= home.houseName %>
          </div>
          <div class="text-center text-sm text-gray-600 mb-2">
            <%= home.location %>
          </div>
          <div class="flex flex-row justify-center items-center gap-2">
            <span class="text-[#ff385c]">₹<%= home.price %></span>
            <span class="text-sm text-[#FFFDEB] bg-[#ff385c] rounded px-2">/ night</span>
            <span class="text-[#ff385c]">★ <%= home.rating %></span>
          </div>
        </li>
      <% }) %>
      </ul>
    </div>
    
  </main>
  
</body>
</html>